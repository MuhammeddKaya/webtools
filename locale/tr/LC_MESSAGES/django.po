# Tool descriptions (updated)
msgid "Split PDF files into individual pages or custom ranges"
msgstr "PDF dosyalarını tek tek sayfalara veya özel aralıklara ayırın"

msgid "Combine multiple PDF files into a single document"
msgstr "Birden fazla PDF dosyasını tek bir belgede birleştirin"

msgid "Convert PDF pages to JPG, PNG or WEBP images"
msgstr "PDF sayfalarını JPG, PNG veya WEBP görsellere dönüştürün"

msgid "Convert and merge images into a PDF document"
msgstr "Görselleri PDF belgesine dönüştürün ve birleştirin"

msgid "Convert PowerPoint presentations to PDF"
msgstr "PowerPoint sunumlarını PDF'e dönüştürün"

msgid "Remove background from any image with AI"
msgstr "Yapay zeka ile herhangi bir görselden arka planı kaldırın"

msgid "Resize images with presets or custom dimensions"
msgstr "Görselleri hazır boyutlar veya özel ölçülerle boyutlandırın"

msgid "Format JSON, convert case, encode/decode and hash text"
msgstr "JSON biçimlendir, büyük/küçük harf dönüştür, kodla/çöz ve metin özetle"

msgid "Clean up text by removing extra spaces, blank lines and more"
msgstr "Fazla boşlukları, boş satırları ve daha fazlasını kaldırarak metni temizleyin"

msgid "Count words, characters, sentences and estimate reading time"
msgstr "Kelimeleri, karakterleri, cümleleri sayın ve okuma süresini tahmin edin"

msgid "Generate custom QR codes with colors and download as PNG or SVG"
msgstr "Renkli özel QR kodları oluşturun, PNG veya SVG olarak indirin"

msgid "Transcribe audio files to text in 12 languages"
msgstr "Ses dosyalarını 12 dilde metne çevirin"

